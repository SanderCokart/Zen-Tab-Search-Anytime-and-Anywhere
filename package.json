{
  "name": "zen-tab-search",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/set-experiment-debug.mjs true && wxt -b firefox",
    "build": "node scripts/set-experiment-debug.mjs false && wxt build -b firefox",
    "zip": "wxt zip -b firefox",
    "lint": "npm run build && web-ext lint --source-dir=.output/firefox-mv2",
    "lint:js": "eslint entrypoints scripts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-icons": "node scripts/generate-icons.mjs",
    "env:use:local": "dotenvx decrypt -f .envx.local --stdout > .env",
    "env:encrypt:local": "dotenvx encrypt -f .envx.local",
    "sign": "dotenvx run -- node scripts/sign.mjs",
    "release": "node scripts/release.mjs",
    "download-signed": "dotenvx run -- node download-signed.js",
    "postinstall": "node scripts/generate-icons.mjs"
  },
  "webExt": {
    "ignoreFiles": [
      "node_modules/**",
      "package.json",
      "package-lock.json",
      "sign.sh",
      "scripts/**",
      "download-signed.js",
      "signed/**",
      "web-ext-artifacts/**",
      ".output/**",
      ".wxt/**",
      "tests/**",
      "icon.png",
      ".gitignore",
      "README.md",
      "eslint.config.js",
      "prettier.config.js",
      "vitest.config.ts",
      "tsconfig.json",
      "wxt.config.ts",
      ".env",
      ".env.example",
      ".env.keys",
      ".envx.local"
    ]
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.1",
    "@eslint/js": "^9.28.0",
    "@types/chrome": "^0.0.323",
    "eslint": "^9.28.0",
    "happy-dom": "^17.4.7",
    "prettier": "^3.5.3",
    "sharp": "^0.34.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1",
    "web-ext": "^10.3.0",
    "wxt": "^0.20.7"
  }
}
